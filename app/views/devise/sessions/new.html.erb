<div class="min-h-screen flex items-center justify-center">
  <div class="max-w-md w-full rounded-lg shadow-lg p-8" style="background-color: rgba(255, 255, 255, 0.04);">
    <h2 class="text-3xl font-bold text-gray-800 mb-6 text-center">Welcome Back</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-6">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 bg-pink-50 rounded-lg outline-none focus:ring-2 focus:ring-[#7F6921] focus:border-transparent" %>
      </div>

      <div class="mb-6">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-4 py-2 border border-gray-300 bg-pink-50 rounded-lg outline-none focus:ring-2 focus:ring-[#7F6921] focus:border-transparent" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-6 flex items-center">
          <%= f.check_box :remember_me, class: "mr-2" %>
          <%= f.label :remember_me, class: "text-sm text-gray-700" %>
        </div>
      <% end %>

      <div class="mb-6">
        <%= f.submit "Log in", class: "w-full text-white font-medium py-3 px-6 rounded-lg cursor-pointer transition duration-200 hover:opacity-70", style: "background-color: #132440;" %>
      </div>
    <% end %>

    <div class="text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
