<div class="max-w-7xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold text-gray-800">My Reading Journey</h1>
    <%= link_to "Add New Book", new_book_path, class: "text-white font-medium py-3 px-6 rounded-lg transition duration-200 hover:opacity-70", style: "background-color: #132440;" %>
  </div>

  <% if notice %>
    <p class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mb-6"><%= notice %></p>
  <% end %>

  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
    <% @books.each do |book| %>
      <%= link_to book, class: "block group" do %>
        <div class="relative">
          <% if book.cover_url.present? %>
            <%= image_tag book.cover_url, class: "w-full h-64 object-cover rounded-lg shadow-md group-hover:shadow-xl transition duration-200", alt: book.title %>
          <% else %>
            <div class="w-full h-64 bg-gray-200 rounded-lg flex items-center justify-center shadow-md">
              <span class="text-gray-400 text-sm text-center px-2"><%= book.title %></span>
            </div>
          <% end %>
          <div class="absolute bottom-0 left-0 right-0 bg-black bg-opacity-60 text-white p-2 rounded-b-lg opacity-0 group-hover:opacity-80 transition duration-200">
            <p class="text-sm font-semibold truncate"><%= book.title %></p>
            <p class="text-xs truncate"><%= book.author %></p>
            <p class="text-xs mt-1"><%= book.status %></p>
            <% if book.rating %>
              <p class="text-xs mt-1 text-yellow-400">★ <%= book.rating %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
