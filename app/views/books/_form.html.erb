<%= form_with(model: book, class: "max-w-2xl mx-auto") do |form| %>
  <% if book.errors.any? %>
    <div class="bg-red-50 border boarder-red-200 text-red-800 px-4 rounded-lg mb-6">
      <h2 class="font-semibold mb-2"><%= pluralize(book.errors.count, "error") %> prohibited this book from being saved:</h2>
      <ul class="list-disc list-inside">
        <% book.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-6">
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :title, class: "w-full px-4 py-2 border border-gray-300 bg-pink-50 rounded-lg outline-none focus:ring-2 focus:ring-[#7F6921] focus:boarder-transparent" %>
  </div>

  <div class="mb-6">
    <%= form.label :author, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :author, class: "w-full px-4 py-2 border border-gray-300 bg-pink-50 rounded-lg outline-none focus:ring-2 focus:ring-[#7F6921] focus:boarder-transparent" %>
  </div>

  <div class="mb-6">
    <%= form.label :pages, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.number_field :pages, class: "w-full px-4 py-2 border border-gray-300 bg-pink-50 rounded-lg outline-none focus:ring-2 focus:ring-[#7F6921] focus:boarder-transparent" %>
  </div>

  <div class="mb-8">
    <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.select :status, Book::STATUSES, { prompt: 'Select a status' }, class: "w-full px-4 py-2 border border-gray-300 bg-pink-50 rounded-lg outline-none focus:ring-2 focus:ring-[#7F6921] focus:boarder-transparent" %>
  </div>

  <div class="mb-6">
    <%= form.label :cover_url, "Book Cover URL (optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :cover_url, placeholder: "https://...", class: "w-full px-4 py-2 border border-gray-300 bg-pink-50 rounded-lg outline-none focus:ring-2 focus:ring-[#7F6921] focus:border-transparent" %>
</div>

  <div style="margin-top: 20px;">
    <%= form.submit class: "w-full text-white font-medium py-3 px-6 rounded-lg cursor-pointer transition duration-200 hover:opacity-70", style: "background-color: #132440;" %>
  </div>
<% end %>
