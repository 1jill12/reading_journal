    <%= book.title %>
  </div>

  <div>
    <strong>Author:</strong>
    <%= book.author %>
  </div>

  <div>
    <strong>Pages:</strong>
    <%= book.pages %>
  </div>

  <div>
    <strong>Status:</strong>
    <%= book.status %>
  </div>

</div>
